# Required
DATABASE_URL=postgres://...
NEXTAUTH_SECRET=run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Admin access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Google OAuth (optional — enables "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email outreach (Resend)
RESEND_API_KEY=
RESEND_FROM=VenueScout <outreach@yourdomain.com>

# Google Maps (Phase 2+)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# AI scoring (Phase 3+)
ANTHROPIC_API_KEY=

# Public v1 API key — required for /api/v1/approved-venues.
# Consumers (e.g. arscca-VMS) authenticate with `Authorization: Bearer <key>`
# or `x-api-key: <key>`. If unset/empty, the endpoint returns 503 (fail closed).
VENUESCOUT_API_KEY=
